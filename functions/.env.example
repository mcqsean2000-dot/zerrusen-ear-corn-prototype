# Copy to a local, untracked .env file only when wiring a real backend.
# Keep real Stripe, Firebase, and service account secrets out of git.

NODE_ENV=development
PORT=8787

# Static storefront URLs used by Stripe-hosted Checkout redirects.
STRIPE_SUCCESS_URL=replace-with-storefront-success-url
STRIPE_CANCEL_URL=replace-with-storefront-cancel-url
CORS_ALLOWED_ORIGINS=replace-with-storefront-origin

# Secret values are intentionally placeholders. Use Stripe test mode first.
STRIPE_SECRET_KEY=replace-with-stripe-test-secret-key
STRIPE_WEBHOOK_SIGNING_SECRET=replace-with-stripe-webhook-signing-secret
STRIPE_CURRENCY=usd

# Firestore project identifier only. Do not place service-account JSON in this file.
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIRESTORE_ORDER_COLLECTION=orderRequests
