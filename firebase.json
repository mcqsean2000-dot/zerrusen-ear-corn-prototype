{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/*.md",
      "**/node_modules/**",
      "node_modules/**",
      "functions",
      "docs/**",
      "functions/**",
      "functions/node_modules/**",
      "admin.html",
      "admin.css",
      "admin-config.js",
      "admin-config.local.example.js",
      "admin-config.local.js",
      "admin.js",
      "admin-live.js",
      "firestore.rules",
      "firestore.indexes.json",
      "package.json",
      "tools/**",
      "dist/**",
      "**/*.zip"
    ],
    "headers": [
      {
        "source": "**/*.@(html|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
